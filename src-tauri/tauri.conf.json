{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SysMonitor",
  "version": "2.0.0",
  "identifier": "com.sysmonitor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SysMonitor",
        "width": 420,
        "height": 440,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "resizable": false,
        "skipTaskbar": true,
        "center": true,
        "visible": false
      },
      {
        "label": "compact",
        "title": "SysMonitor Compact",
        "url": "/compact",
        "width": 360,
        "height": 30,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true,
        "x": 0,
        "y": 0
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
